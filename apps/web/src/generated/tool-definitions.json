{
  "tools": [
    {
      "name": "todos_list",
      "description": "Todo一覧を取得します。フィルタで絞り込めます。",
      "category": "todos",
      "params": [
        {
          "name": "completed",
          "type": "boolean",
          "required": false,
          "description": "完了状態でフィルタ"
        },
        {
          "name": "parentId",
          "type": "string",
          "required": false,
          "description": "親TodoのIDでフィルタ。'null'でルートのみ"
        },
        {
          "name": "dueBefore",
          "type": "string",
          "required": false,
          "description": "指定日以前の締切でフィルタ（YYYY-MM-DD形式）"
        },
        {
          "name": "sort",
          "type": "order | dueDate",
          "required": false,
          "description": "ソート順。'dueDate'で締切日昇順（null末尾）"
        },
        {
          "name": "projectId",
          "type": "string",
          "required": false,
          "description": "プロジェクトIDでフィルタ"
        }
      ]
    },
    {
      "name": "todos_get",
      "description": "Todo単体を取得します。",
      "category": "todos",
      "params": [
        {
          "name": "id",
          "type": "string",
          "required": true,
          "description": "取得するTodoのID"
        }
      ]
    },
    {
      "name": "todos_create",
      "description": "新しいTodoを作成します。",
      "category": "todos",
      "params": [
        {
          "name": "title",
          "type": "string",
          "required": true,
          "description": "タイトル（255文字以内）"
        },
        {
          "name": "projectId",
          "type": "string",
          "required": false,
          "description": "プロジェクトID"
        },
        {
          "name": "parentId",
          "type": "string",
          "required": false,
          "description": "親TodoのID（省略でルートに作成）"
        },
        {
          "name": "dueDate",
          "type": "string",
          "required": false,
          "description": "締切日（YYYY-MM-DD形式）"
        },
        {
          "name": "startTime",
          "type": "string",
          "required": false,
          "description": "開始時間（HH:MM形式、dueDateが必要）"
        },
        {
          "name": "endTime",
          "type": "string",
          "required": false,
          "description": "終了時間（HH:MM形式、dueDateが必要）"
        },
        {
          "name": "priority",
          "type": "high | medium | low",
          "required": false,
          "description": "優先度"
        },
        {
          "name": "categoryIcon",
          "type": "work | personal | shopping | health | study | idea",
          "required": false,
          "description": "カテゴリアイコン"
        },
        {
          "name": "description",
          "type": "string",
          "required": false,
          "description": "メモ・詳細情報（5000文字以内）"
        }
      ]
    },
